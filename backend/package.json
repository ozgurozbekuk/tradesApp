{
  "name": "tradesapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "node --import tsx --test tests/**/*.test.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "eval:agent": "node --import tsx scripts/eval/agent-eval.ts",
    "eval:conversation-v2-semantic": "node --import tsx scripts/eval/conversation-v2-semantic-eval.ts",
    "eval:learning-export": "node --import tsx scripts/eval/export-learning-eval.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@clerk/express": "^1.7.4",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.4.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
